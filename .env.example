# Local dev defaults match docker-compose.yml (non-default ports to avoid
# clashing with other projects' Postgres/Redis on this machine)
DATABASE_URL=postgres://rivalwatch:rivalwatch@localhost:5433/rivalwatch
REDIS_URL=redis://localhost:6380

# packages/llm only — required for classify/brief/eval, not for crawl/extract/diff.
# LLM_PROVIDER=auto picks anthropic > gemini > groq (first configured key wins).
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Email delivery — apps/worker/src/email.ts only (alert + weekly brief sending)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Raw HTML archive. Leave R2_* empty to use local filesystem storage (STORAGE_DIR).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
STORAGE_DIR=.storage

# Billing — apps/web/lib/lemonsqueezy.ts + app/api/webhooks/ls/route.ts only
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_STARTER_VARIANT_ID=
LEMONSQUEEZY_PRO_VARIANT_ID=

# Auth (Phase 2)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

APP_URL=http://localhost:3000
