{
  "name": "rivalwatch",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter worker dev",
    "db:generate": "pnpm --filter @rivalwatch/db generate",
    "db:migrate": "pnpm --filter @rivalwatch/db migrate",
    "db:studio": "pnpm --filter @rivalwatch/db studio",
    "test": "turbo run test",
    "test:core": "pnpm --filter @rivalwatch/core test",
    "eval": "pnpm --filter @rivalwatch/llm eval",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "worker:trigger": "pnpm --filter worker trigger"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.1.0",
    "eslint": "^9.39.4",
    "tsx": "^4.22.5",
    "turbo": "^2.10.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  }
}
